# ── Robinhood Chain ──────────────────────────────────────────────────────────
RH_CHAIN_RPC=https://rpc.mainnet.chain.robinhood.com
PREDICT_VAULT_ADDRESS=0x...           # deployed PredictVault on RH Chain
OPERATOR_PRIVATE_KEY=0x...            # operator wallet (must match vault.operator)
RH_CHAIN_START_BLOCK=0                # block to start scanning from

# ── Polygon ───────────────────────────────────────────────────────────────────
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
OPERATOR_POLYGON_PRIVATE_KEY=0x...    # can be same key or separate Polygon wallet

# ── LayerZero ─────────────────────────────────────────────────────────────────
# Endpoint V2 addresses (LayerZero V2)
LZ_ENDPOINT_RH_CHAIN=0x...            # LayerZero V2 endpoint on RH Chain mainnet
LZ_ENDPOINT_POLYGON=0x1a44076050125825900e736c501f859c50fE728c
LZ_EID_RH_CHAIN=0                    # EID assigned by LayerZero for RH Chain
LZ_EID_POLYGON=30109

# OFT adapter addresses for bridged USDC
USDC_OFT_RH_CHAIN=0x...              # OFT USDC on RH Chain (deploy OFT adapter)
USDC_OFT_POLYGON=0x...               # OFT USDC on Polygon (or native USDC if using CCTP)

# ── Tokens ────────────────────────────────────────────────────────────────────
USDC_POLYGON=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359  # native USDC on Polygon

# ── Uniswap V3 (Polygon) ──────────────────────────────────────────────────────
UNISWAP_ROUTER_POLYGON=0x3fC91A3afd70395Cd496C647d5a6CC9D4B2b7FAD
UNISWAP_QUOTER_POLYGON=0x61fFE014bA17989E743c5F6cB21bF9697530B21e

# ── Polymarket CLOB ───────────────────────────────────────────────────────────
# The trading wallet on Polygon that holds USDC and places orders.
# Must be pre-funded with USDC float to cover user positions.
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CTF_EXCHANGE=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E  # Polygon mainnet
POLYMARKET_NEG_RISK_EXCHANGE=0xC5d563A36AE78145C45a50134d48A1215220f80a
POLYMARKET_USDC=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174  # USDC.e (bridged) on Polygon

# ── Agent ─────────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=15000        # how often to poll (ms)
LOG_LEVEL=info
