{
  "name": "@rwaforge/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK (viem/wagmi) for the RWAForge protocol on Robinhood Chain.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HockeyPlaya48/RWAForge.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/HockeyPlaya48/RWAForge#readme",
  "bugs": {
